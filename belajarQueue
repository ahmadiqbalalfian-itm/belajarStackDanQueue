#include <iostream>
using namespace std;
#define max 5
string data [max];
int top=0;

		bool isFull(){
			if(top>=max){
				return true;
			} else{
				return false;
			}
		}
		
		bool isEmpty(){
			if(top==0){
				return true;
			} else {
				return false;
			}
		}		
		
		void enqueue(){
			if(!isFull()){
				system("cls");
				cout<<"Masukkan data ...";
				cin>>data[top];
				top++;
			}
		}
		
		void dequeue(){
			if(!isEmpty()){
				for(int i=0; i<top-1;i++){
					data[i]=data[i+1];
				}
			}
			top--;
		}
		
		void clear(){
			top=0;
		}
		
			
		void tampil(){
			if(!isEmpty()){
				cout<<"Antrian data"<<endl;
				for(int i=top-1;i>=0;i--){
					cout<<i+1<<". "<<data[i]<<endl;
				}
			}else{
				cout<<"Antrian kosong";
			}
			
			if(isFull()){
				cout<<"Antrian penuh"<<endl;
			}
			cout<<"\n+++++++++++++++++++++++++++\n"<<endl;
		}

int main(){
	int pil;
	queue:
		system ("cls");
		tampil();
		
		cout<<"Menu Pilihan\n1. Enqeue\n2. Dequeue\n3. Clear\n Pilihan... :";
		cin>>pil;
		if(pil==1){
			cout<<"Enqueue"<<endl;
			enqueue();
			goto queue;
		} else if (pil==2){
			cout<<"Dequeue"<<endl;
			dequeue();
			goto queue;
		} else if(pil==3){
			clear();
			goto queue;
		}
}
