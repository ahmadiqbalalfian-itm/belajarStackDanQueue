void stack(){
	string data [max];
	int top;
	bool isEmpty(){
		if(top==0){
			return true;
		} else {
			return false;
		}
	}
	
	bool isFull(){
		if (top>= max){
			return true;
		} else {
			return false;
		}
	}
	
	void tampil (){
		if(!isEmpty()){
			cout<<"Data yang tersimpan"<<endl;
			for(int i=0;i<top;i++){
				cout<<i+1<<"."<<data[i]<<endl;
			}
		}else {
			cout<<"Data tidak tersedia"<<endl;
		}
		
		if (isFull()){
			cout<<"Data sudah penuh!"<<endl;
		}
		cout<<endl;
		cout<<"////////////////////////////////\n\n";
	}
	
	void push(){
		if(!isFull()){
			cout<<"Masukkan data : "<<endl;
			cin>>data[top];
			top++;
		}
	}
	
	void pop(){
		if(!isEmpty()){
			top--;
		}
	}
	
	void clear(){
		top=0;
	}
}

