// 2. FUNGSI PENCARIAN (BUBBLE SORT + BINARY SEARCH)
// ==========================================		
void cariData() {
/*a*/if(top == 0) {
        cout << "Data kosong, tidak ada yang bisa dicari!\n";
        return;
    }
/*a*/string target;
    cout << "Masukkan data yang ingin dicari: ";
    cin >> target;
// b. Copy data biar stack/queue asli nggak rusak urutannya
    string dataCopy[ARRAY];
    for(int i = 0; i < top; i++) {
        dataCopy[i] = data[i];
    }
// c. Urutkan data salinan pakai BUBBLE SORT
    for(int i = 0; i < top - 1; i++) {
        for(int j = 0; j < top - i - 1; j++) {
            if(dataCopy[j] > dataCopy[j + 1]) {
                string temp = dataCopy[j];
                dataCopy[j] = dataCopy[j + 1];
                dataCopy[j + 1] = temp;
            }
        }
    }
// d. Cari pakai BINARY SEARCH
    int kiri = 0;
    int kanan = top - 1;
    bool ketemu = false;
    while(kiri <= kanan) {
        int tengah = kiri + (kanan - kiri) / 2;
        // INGAT: Di sini harus pakai dataCopy, BUKAN dataAsli!
        if(dataCopy[tengah] == target) {
            ketemu = true;
            break;
        } else if(dataCopy[tengah] < target) {
            kiri = tengah + 1;
        } else {
            kanan = tengah - 1;
        }
    }
// e. Output Hasil Pencarian
    cout << "--------------------------------\n";
    if(ketemu) {
        cout << "=> HASIL: Data '" << target << "' DITEMUKAN!\n";
    } else {
        cout << "=> HASIL: Data '" << target << "' TIDAK DITEMUKAN!\n";
    }
    cout << "--------------------------------\n";
    system("pause");/*setelah system menampilkan status pencarian data,
    maka system dipause agar pesan sempat dibaca dengan notif :
    "Press any key to continue"
    apabila tidak dipause, maka system akan langsung membuka
	opsimenu 1-5. Sehingga user belum sempat membaca hasil pencarian.
	*/ 
}
