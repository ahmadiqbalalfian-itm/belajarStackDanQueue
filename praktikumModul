#include <iostream>
using namespace std;
#define max 3
string data [max];
int top;
bool isEmpty(){
	if(top==0){
		return true;
	} else {
		return false;
	}
}

bool isFull(){
	if (top>= max){
		return true;
	} else {
		return false;
	}
}

void tampil (){
	if(!isEmpty()){
		cout<<"Data yang tersimpan"<<endl;
		for(int i=0;i<top;i++){
			cout<<i+1<<"."<<data[i]<<endl;
		}
	}else {
		cout<<"Data tidak tersedia"<<endl;
	}
	
	if (isFull()){
		cout<<"Data sudah penuh!"<<endl;
	}
	cout<<endl;
	cout<<"////////////////////////////////";
}

void push(){
	if(!isFull()){
		cout<<"Masukkan data : "<<endl;
		cin>>data[top];
		top++;
	}
}

void pop(){
	if(!isEmpty()){
		top--;
	}
}

void clear(){
	top=0;
}

int main(){
	int pil;
	stack:
	system("cls"); tampil;
	cout<<"Pilih menu : \n1. Push\n2. Pop\n3. Clear\nPilih...";
	cin>>pil;
	if(pil==1){
		push();
		goto stack;
	}else if (pil == 2){
		pop();
		goto stack;
	} else{
		clear();
		goto stack;
	}
}
